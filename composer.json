{
  "type": "project",
  "license": "proprietary",
  "minimum-stability": "stable",
  "prefer-stable": true,
  "require": {
    "php": ">=8.5",
    "ext-ctype": "*",
    "ext-exif": "*",
    "ext-gd": "*",
    "ext-iconv": "*",
    "ext-intl": "*",
    "deeplcom/deepl-php": "1.*",
    "doctrine/dbal": "4.*",
    "doctrine/doctrine-bundle": "3.*",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "doctrine/orm": "3.*",
    "google/apiclient": "^2.18",
    "knpuniversity/oauth2-client-bundle": "^2.20",
    "league/commonmark": "^2.8",
    "league/oauth2-github": "^3.1",
    "league/oauth2-google": "*",
    "nelmio/cors-bundle": "^2.5",
    "nyholm/psr7": "1.8.*",
    "phpdocumentor/reflection-docblock": "5.*",
    "phpstan/phpdoc-parser": "1.*",
    "symfony/asset": "*",
    "symfony/asset-mapper": "*",
    "symfony/clock": "*",
    "symfony/console": "*",
    "symfony/doctrine-messenger": "*",
    "symfony/dotenv": "*",
    "symfony/expression-language": "*",
    "symfony/flex": "^2",
    "symfony/form": "*",
    "symfony/framework-bundle": "*",
    "symfony/http-client": "*",
    "symfony/http-foundation": "*",
    "symfony/intl": "*",
    "symfony/mailer": "*",
    "symfony/mime": "*",
    "symfony/monolog-bundle": "^3.0|^4.0.2",
    "symfony/notifier": "*",
    "symfony/process": "*",
    "symfony/property-access": "*",
    "symfony/property-info": "*",
    "symfony/requirements-checker": "^2.0",
    "symfony/runtime": "*",
    "symfony/security-bundle": "*",
    "symfony/security-csrf": "*",
    "symfony/serializer": "*",
    "symfony/stimulus-bundle": "2.*",
    "symfony/string": "*",
    "symfony/translation": "*",
    "symfony/twig-bundle": "*",
    "symfony/uid": "*",
    "symfony/ux-dropzone": "v2.*",
    "symfony/ux-icons": "v2.*",
    "symfony/ux-turbo": "v2.*",
    "symfony/ux-twig-component": "v2.*",
    "symfony/validator": "*",
    "symfony/web-link": "*",
    "symfony/yaml": "*",
    "symfonycasts/sass-bundle": "^0.8",
    "symfonycasts/verify-email-bundle": "^1.16",
    "twig/extra-bundle": "^2.12|^3.0",
    "twig/intl-extra": "^3.0",
    "twig/markdown-extra": "^3.24",
    "twig/string-extra": "^3.17",
    "twig/twig": "^3.0",
    "webonyx/graphql-php": "^15.14"
  },
  "config": {
    "allow-plugins": {
      "php-http/discovery": true,
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "sort-packages": true
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "replace": {
    "symfony/polyfill-ctype": "*",
    "symfony/polyfill-iconv": "*",
    "symfony/polyfill-php72": "*",
    "symfony/polyfill-php73": "*",
    "symfony/polyfill-php74": "*",
    "symfony/polyfill-php80": "*",
    "symfony/polyfill-php81": "*",
    "symfony/polyfill-php82": "*",
    "symfony/polyfill-php83": "*",
    "symfony/polyfill-php84": "*"
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd",
      "importmap:install": "symfony-cmd",
      "requirements-checker": "script"
    },
    "post-install-cmd": [
      "@auto-scripts"
    ],
    "post-update-cmd": [
      "@auto-scripts"
    ]
  },
  "conflict": {
    "symfony/symfony": "*"
  },
  "extra": {
    "symfony": {
      "allow-contrib": false,
      "require": "8.0.*"
    }
  },
  "require-dev": {
    "symfony/browser-kit": "*",
    "symfony/css-selector": "*",
    "symfony/debug-bundle": "*",
    "symfony/maker-bundle": "^1.0",
    "symfony/stopwatch": "*",
    "symfony/web-profiler-bundle": "*"
  }
}
