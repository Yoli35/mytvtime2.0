<!DOCTYPE html>
<html lang="{{ app.locale }}">
<head>
    <meta charset="UTF-8">
    <meta name="theme-color" content="#000000">
    <meta name="msapplication-tap-highlight" content="no">
    <meta name="referrer" content="no-referrer-when-downgrade">
    <title>{% block title %}Welcome!{% endblock %}</title>
    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/icons/android-chrome-192x192.png" type="image/png" sizes="192x192">
    <link rel="icon" href="/icons/android-chrome-512x512.png" type="image/png" sizes="512x512">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    {% block stylesheets %}
        <link rel="stylesheet" href="{{ asset('styles/app.scss') }}">
    {% endblock %}

    {% block javascripts %}
        {% block importmap %}{{ importmap('app') }}{% endblock %}
    {% endblock %}
</head>
<body>
{% set route = app.request.attributes.get('_route') %}
{% set route_params = app.request.attributes.get('_route_params') %}
{% block body %}{% endblock %}
{% include "_blocks/_flash_messages.html.twig" %}
{% include "_blocks/settings/_accent_color.html.twig" %}
{% include "_blocks/settings/_schedule_menu.html.twig" %}
{% include "_blocks/settings/_what_next.html.twig" %}
{% include "_blocks/list/_user_list.html.twig" %}
{% include "_blocks/list/_tools_submenu_list.html.twig" %}
<div class="global-tools{% if app.environment is same as 'dev' %} dev{% endif %}">
    <div class="to-top" data-title="{{ 'Back to top'|trans }}">{{ ux_icon('mdi:arrow-up') }}</div>
    <div class="theme-toggler" data-title="{{ 'Toggle text color'|trans }}">{{ ux_icon('mdi:theme-light-dark') }}</div>
    <div class="preview-toggler" data-title="{{ 'Toggle image preview'|trans }}">{{ ux_icon('mdi:eye') }}</div>
</div>
<div class="diaporama"></div>
</body>
</html>
{% if app.user and route is not null %}
    {{ logHistory(app.user, block('title'), path(route, route_params)) }}
{% endif %}
