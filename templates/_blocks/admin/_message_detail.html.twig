<section class="admin__message__details">
    <h2>{{ 'Message details'|trans }}</h2>
    <div class="admin__message__details__container">
        <div class="admin_message_tools">
            <a href="{{ path('admin_message_delete', {id: message.id}) }}" class="button admin__message__details__delete" onclick="return confirm('{{ 'Are you sure you want to delete this message?'|trans }}');">
                {{ 'Delete message'|trans }}
            </a>
            <a href="{{ path('admin_messages') }}" class="button admin__message__details__navigation">
                {{ 'Back to messages'|trans }}
            </a>
            {% if previous %}
                <a href="{{ path('admin_message_detail', {'id': previous.id}) }}" data-title="{{ 'Previous message'|trans }}" class="button admin__message__details__navigation">
                    {{ ux_icon('mdi:chevron-down') }}
                </a>
            {% else %}
                <div data-title="{{ 'No previous message'|trans }}" class="button admin__message__details__navigation none">
                    {{ ux_icon('mdi:chevron-up') }}
                </div>
            {% endif %}
            {% if next %}
                <a href="{{ path('admin_message_detail', {'id': next.id}) }}" data-title="{{ 'Next message'|trans }}" class="button admin__message__details__navigation">
                    {{ ux_icon('mdi:chevron-up') }}
                </a>
            {% else %}
                <div data-title="{{ 'No next message'|trans }}" class="button admin__message__details__navigation none">
                    {{ ux_icon('mdi:chevron-up') }}
                </div>
            {% endif %}
        </div>
        <div class="admin__message__details__field">
            <strong>{{ 'Name'|trans }}:</strong> {{ message.name }}
            <form method="post" action="{{ path('admin_message_block_name', {id: message.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_message_block_name_' ~ message.id) }}">
                <button type="submit" {% if nameBlocked %}disabled{% endif %}>{{ 'Block this username'|trans }}</button>
            </form>
        </div>
        <div class="admin__message__details__field">
            <strong>{{ 'Email'|trans }}:</strong> <a href="mailto:{{ message.email }}" class="button">{{ message.email }}</a>
            <form method="post" action="{{ path('admin_message_block_email', {id: message.id}) }}" style="display:inline">
                <input type="hidden" name="_token" value="{{ csrf_token('admin_message_block_email_' ~ message.id) }}">
                <button type="submit" {% if emailBlocked %}disabled{% endif %}>{{ 'Block this email'|trans }}</button>
            </form>
        </div>
        <div class="admin__message__details__field">
            <strong>{{ 'Subject'|trans }}:</strong> {{ message.subject }}
        </div>
        <div class="admin__message__details__field">
            <strong>{{ 'Date'|trans }}:</strong> {{ message.date|format_datetime('short', 'short') }}
        </div>
        <div class="admin__message__details__field">
            <strong>{{ 'Message'|trans }}:</strong>
            <p>{{ message.message|nl2br }}</p>
        </div>
    </div>
</section>
